{
  "name": "lucid-ui",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --filter @pandaworks-sw/demo dev",
    "build": "pnpm --filter @pandaworks-sw/lucid-ui build:lib && pnpm --filter @pandaworks-sw/demo build",
    "lint": "biome check && pnpm --filter @pandaworks-sw/demo lint",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "format:check": "biome format",
    "test:ui-audit": "node scripts/ui-audit-playwright.mjs --serve"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "playwright": "^1.59.1"
  }
}
