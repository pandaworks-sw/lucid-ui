{
  "name": "pandawork-ui",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --filter @pandaworks-ui/demo dev",
    "build": "pnpm registry:build && pnpm --filter @pandaworks-ui/demo build",
    "registry:build": "pnpm --filter @pandaworks-ui/registry registry:build",
    "lint": "pnpm --filter @pandaworks-ui/demo lint"
  }
}
